// =============================================================================
// 근태 관리 모듈 (Attendance Management System) - atd_
// =============================================================================
// DB: PostgreSQL
// ID: BIGSERIAL (자동 증가)
// 테이블 프리픽스: atd_
// 공통 참조: com_employee (직원 마스터), com_organization (조직)
// 작성일: 2026-03-05
// 버전: 1.0.0
// =============================================================================

// -----------------------------------------------------------------------------
// [공통 모듈 참조 테이블]
// -----------------------------------------------------------------------------

Table com_employee [headercolor: #7f8c8d, note: '공통 모듈 - 직원 마스터 (Common 모듈)'] {
  emp_id         BIGINT    [pk, note: '직원 ID (PK)']
}

// =============================================================================
// 섹션 1. 장치 및 로우 로그 (Device & Raw Logs)
// =============================================================================

Table atd_device [
  headercolor: #34495e,
  note: '''
  근태 측정 장치 관리 테이블 (Hikvision Face Recognition 등).
  장치의 IP 주소, 설치 위치, 상태 등을 관리.
  '''
] {
  device_id     SERIAL         [pk, note: '장치 PK']
  device_name   VARCHAR(100)   [not null, note: '장치 이름 (예: 정문 인식기)']
  device_ip     VARCHAR(50)    [note: '장치 IP 주소']
  mac_address   VARCHAR(100)   [note: 'MAC 주소']
  location      VARCHAR(200)   [note: '설치 위치']
  status        VARCHAR(20)    [not null, default: 'ACTIVE', note: '상태: ACTIVE / INACTIVE / MAINTENANCE']
  
  created_at    TIMESTAMPTZ    [not null, default: `now()`, note: '생성일시']
  updated_at    TIMESTAMPTZ    [not null, default: `now()`, note: '최종 수정일시']
}

Table atd_raw_log [
  headercolor: #34495e,
  note: '''
  장치로부터 수집된 원천 근태 로그.
  Hikvision ISAPI 등을 통해 가져온 가공되지 않은 모든 체크인/체크아웃 데이터.
  '''
] {
  log_id            BIGSERIAL      [pk, note: '로그 PK']
  emp_id            BIGINT         [not null, note: 'com_employee FK (사번 기반 매핑)']
  device_id         INT            [note: 'atd_device FK']
  
  event_time        TIMESTAMPTZ    [not null, note: '이벤트 발생 시각']
  event_type        VARCHAR(50)    [not null, note: '이벤트 유형: CHECK_IN / CHECK_OUT / FACE_MATCH']
  access_method     VARCHAR(50)    [note: '인증 방식: FACE / CARD / FINGERPRINT / PASSWORD']
  
  raw_data          JSONB          [note: '장치에서 수신한 원본 JSON 데이터 전체 (Hikvision AcsEvent)']
  source_api        VARCHAR(100)   [note: '데이터 수집 출처 (예: ISAPI_AcsEvent)']

  created_at        TIMESTAMPTZ    [not null, default: `now()`, note: '시스템 기록 시각']

  indexes {
    emp_id          [name: 'idx_atd_raw_emp']
    event_time      [name: 'idx_atd_raw_time']
    (emp_id, event_time) [name: 'idx_atd_raw_emp_time']
  }
}

// =============================================================================
// 섹션 2. 근무 스케줄 설정 (Shift & Schedule)
// =============================================================================

Table atd_shift [
  headercolor: #1abc9c,
  note: '''
  근무 교대(Shift) 정의 마스터.
  표준 근무, 오전 반차, 오후 반차, 야간 근무 등 정의.
  '''
] {
  shift_id          SERIAL         [pk, note: '교대 PK']
  shift_code        VARCHAR(20)    [unique, not null, note: '교대 코드 (예: STD, MORNING_HALF)']
  shift_name        VARCHAR(100)   [not null, note: '교대 이름']
  
  start_time        TIME           [not null, note: '정규 출근 시각']
  end_time          TIME           [not null, note: '정규 퇴근 시각']
  
  lunch_start       TIME           [note: '점심시간 시작']
  lunch_end         TIME           [note: '점심시간 종료']
  
  grace_period_in   INT            [default: 0, note: '지각 허용 시간 (분)']
  grace_period_out  INT            [default: 0, note: '조퇴 허용 시간 (분)']
  
  min_work_hours    DECIMAL(4,2)   [default: 8.0, note: '최소 소정 근로 시간']
  
  is_active         BOOLEAN        [default: true, note: '활성 여부']
  
  created_at        TIMESTAMPTZ    [not null, default: `now()`]
  updated_at        TIMESTAMPTZ    [not null, default: `now()`]
}

Table atd_employee_schedule [
  headercolor: #1abc9c,
  note: '''
  직원별 근무 스케줄 할당 테이블.
  특정 기간 동안 직원이 어떤 Shift를 따르는지 정의.
  '''
] {
  schedule_id       BIGSERIAL      [pk, note: '스케줄 PK']
  emp_id            BIGINT         [not null, note: 'com_employee FK']
  shift_id          INT            [not null, note: 'atd_shift FK']
  
  start_date        DATE           [not null, note: '적용 시작 날짜']
  end_date          DATE           [note: '적용 종료 날짜 (9999-12-31 이면 무기한)']
  
  work_days_mask    SMALLINT       [default: 62, note: '근무 요일 비트마스크 (월~금=62)']
  
  created_at        TIMESTAMPTZ    [not null, default: `now()`]
  updated_at        TIMESTAMPTZ    [not null, default: `now()`]

  indexes {
    (emp_id, start_date) [name: 'idx_atd_sched_emp_date']
  }
}

// =============================================================================
// 섹션 3. 근태 정산 결과 (Calculated Results)
// =============================================================================

Table atd_daily_summary [
  headercolor: #e67e22,
  note: '''
  일별 근태 정산 결과 테이블 (로우 로그를 바탕으로 계산).
  hr_attendance 테이블과 연동되거나 이를 대체할 수 있음 (상세화).
  '''
] {
  summary_id        BIGSERIAL      [pk, note: '정산 PK']
  emp_id            BIGINT         [not null, note: 'com_employee FK']
  work_date         DATE           [not null, note: '근무 날짜']
  shift_id          INT            [note: 'atd_shift FK']
  
  actual_check_in   TIMESTAMPTZ    [note: '실제 출근 시각 (로우 로그 중 최소)']
  actual_check_out  TIMESTAMPTZ    [note: '실제 퇴근 시각 (로우 로그 중 최대)']
  
  working_minutes   INT            [default: 0, note: '실 근무 시간 (분)']
  overtime_minutes  INT            [default: 0, note: '초과 근무 시간 (분)']
  late_minutes      INT            [default: 0, note: '지각 시간 (분)']
  early_leave_minutes INT          [default: 0, note: '조퇴 시간 (분)']
  
  attendance_status VARCHAR(20)    [not null, note: '상태: NORMAL / LATE / EARLY_LEAVE / ABSENT / HOLIDAY / PAID_LEAVE / UNPAID_LEAVE / MISSED_PUNCH']
  
  is_missed_punch   BOOLEAN        [default: false, note: '지문인식 누락 여부 (깜빡함)']
  leave_request_id  BIGINT         [note: 'hr_leave_request FK (휴가 연동 시)']
  
  is_modified       BOOLEAN        [default: false, note: '수동 수정 여부']
  modified_by       BIGINT         [note: '수정한 관리자 ID']
  
  note              TEXT           [note: '특이사항 (예: 휴가 사유, 누락 사유 등)']
  
  created_at        TIMESTAMPTZ    [not null, default: `now()`]
  updated_at        TIMESTAMPTZ    [not null, default: `now()`]

  indexes {
    (emp_id, work_date) [unique, name: 'uq_atd_summary_emp_date']
    work_date           [name: 'idx_atd_summary_date']
    attendance_status   [name: 'idx_atd_summary_status']
    leave_request_id    [name: 'idx_atd_summary_leave']
  }
}

// -----------------------------------------------------------------------------
// [신규] 출퇴근 누락 보정 신청 (Punch Correction Request)
// -----------------------------------------------------------------------------
Table atd_punch_correction [
  headercolor: #e67e22,
  note: '''
  직원이 지문인식을 깜빡했을 때 제출하는 보정 신청서.
  승인 시 atd_daily_summary 의 실제 시각(actual_check_in/out)을 업데이트함.
  '''
] {
  correction_id     BIGSERIAL      [pk, note: '보정 PK']
  emp_id            BIGINT         [not null, note: '신청 직원 FK']
  work_date         DATE           [not null, note: '누락된 날짜']
  
  punch_type        VARCHAR(10)    [not null, note: '누락 유형: IN / OUT / BOTH']
  requested_time    TIMESTAMPTZ    [not null, note: '실제 출퇴근했다고 주장하는 시각']
  
  reason            TEXT           [note: '누락 사유 (예: 지문인식기 오류, 깜빡함)']
  status            VARCHAR(20)    [not null, default: 'PENDING', note: '상태: PENDING / APPROVED / REJECTED']
  
  approved_by       BIGINT         [note: '승인 관리자 FK']
  approved_at       TIMESTAMPTZ
  
  created_at        TIMESTAMPTZ    [not null, default: `now()`]
  updated_at        TIMESTAMPTZ    [not null, default: `now()`]

  indexes {
    emp_id          [name: 'idx_punch_corr_emp']
    work_date       [name: 'idx_punch_corr_date']
    status          [name: 'idx_punch_corr_status']
  }
}

Table atd_holiday [
  headercolor: #e67e22,
  note: '''
  공휴일 및 회사 휴무일 관리.
  해당 날짜는 근태 정산 시 제외되거나 특별 수당 산정의 기준이 됨.
  '''
] {
  holiday_id        SERIAL         [pk, note: '공휴일 PK']
  holiday_date      DATE           [unique, not null, note: '날짜']
  holiday_name      VARCHAR(100)   [not null, note: '공휴일 이름']
  holiday_name_vi   VARCHAR(100)   [note: '공휴일 이름 (베트남어)']
  is_paid           BOOLEAN        [default: true, note: '유급 휴무 여부']
  
  region            VARCHAR(10)    [default: 'VN', note: '지역: VN / KR (베트남/한국)']
}

// =============================================================================
// Ref: 외래키 관계 정의
// =============================================================================

Ref: atd_raw_log.emp_id > com_employee.emp_id
Ref: atd_raw_log.device_id > atd_device.device_id

Ref: atd_employee_schedule.emp_id > com_employee.emp_id
Ref: atd_employee_schedule.shift_id > atd_shift.shift_id

Ref: atd_daily_summary.emp_id > com_employee.emp_id
Ref: atd_daily_summary.shift_id > atd_shift.shift_id

// HR 모듈 연동 (Cross-Module)
// Ref: atd_daily_summary.leave_request_id > hr_leave_request.request_id

Ref: atd_punch_correction.emp_id > com_employee.emp_id
Ref: atd_punch_correction.approved_by > com_employee.emp_id

// =============================================================================
// TableGroup: 도메인 그룹핑
// =============================================================================

TableGroup "근태 로우 데이터 (Raw Data)" {
  atd_device
  atd_raw_log
}

TableGroup "근태 설정 및 스케줄 (Settings)" {
  atd_shift
  atd_employee_schedule
}

TableGroup "근태 정산 결과 (Summary)" {
  atd_daily_summary
  atd_punch_correction
  atd_holiday
}
